<Window x:Class="pizzeria.EditClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pizzeria"
        mc:Ignorable="d"
        Title="Редагувати клієнта" Style="{StaticResource WinStyleAddEdit}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid Margin="10">
            <StackPanel>
                <Label Content="Прізвище та ім'я:" FontSize="14" FontWeight="Bold" />
                <TextBox Name="FullNameTextBox" FontSize="14" Height="25"/>
                <Label Content="Телефон:" FontSize="14" FontWeight="Bold"/>
                <TextBox Name="PhoneTextBox" FontSize="14" Height="25"/>
                <Button Content="Зберегти" Click="SaveButton_Click" Style="{StaticResource btn}"  Margin="20"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
