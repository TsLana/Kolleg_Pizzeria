<Window x:Class="pizzeria.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pizzeria"
        mc:Ignorable="d"
        Title="Вхід до системи" Style="{StaticResource WinStyle}"  Height="500" Width="450" WindowStartupLocation="CenterScreen">
    <Grid>
            <TextBlock Text="ВХІД У СИСТЕМУ" FontSize="40" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,80,0,0"/>

            <StackPanel Margin="0,160,0,0">
                <TextBlock Text="Логін:" FontSize="22" FontWeight="Bold" Margin="20,0,0,0" FontFamily="Showcard Gothic"/>
                <TextBox x:Name="FullNameTextBox" Height="40" Width="360" HorizontalAlignment="Center" FontSize="20" VerticalAlignment="Center"/>

                <TextBlock Text="Пароль:" FontSize="22" FontWeight="Bold" Margin="20,30,0,0" FontFamily="Showcard Gothic"/>
                <PasswordBox x:Name="PasswordBox"  Height="40" Width="360" HorizontalAlignment="Center" FontSize="20" VerticalAlignment="Center"/>
                <TextBlock x:Name="ErrorTextBlock" Foreground="#FFB5870A" FontWeight="Bold"
               Text="" Margin="0,10,0,0" FontSize="20" FontStyle="Italic" HorizontalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0" >
                    <Button Content="Увійти" Click="LoginButton_Click"
                            Width="250" Height="50"
                            Background="#FFB5870A" Foreground="Black" FontWeight="Bold" Margin="0,0,10,0" FontSize="18"/>
                    <Button Content="Вийти" Click="ExitButton_Click"
                            Width="100" Height="50"
                            Background="#FF585449" Foreground="Black" FontWeight="Bold" FontSize="18"/>
                </StackPanel>

            
            </StackPanel>
        </Grid>
</Window>
