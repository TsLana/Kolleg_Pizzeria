<Window x:Class="pizzeria.MenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Меню" Style="{StaticResource WinStyle}"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Фільтрація:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="16"/>
            <ComboBox x:Name="CategoryFilterComboBox" Width="200" SelectionChanged="CategoryFilterComboBox_SelectionChanged" FontSize="14"/>
        </StackPanel>

        <DataGrid x:Name="MenuDataGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" FontSize="14">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Назва" Binding="{Binding dish_name}" Width="280"/>
                <DataGridTemplateColumn Header="Інгредієнти" Width="500">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding dish_ingredients}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Top"
                       Padding="5"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Ціна" Binding="{Binding dish_price}" Width="100"/>
                <DataGridTextColumn Header="К-сть порцій" Binding="{Binding servings_per_day}" Width="120"/>
                <DataGridTextColumn Header="Вага" Binding="{Binding dish_weight}" Width="100"/>
                <DataGridTextColumn Header="Категорія" Binding="{Binding category_name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="На головний" Click="BackToMain_Click" Style="{StaticResource btnOrange}"/>
            <Button Content="Додати" Click="AddDish_Click" Style="{StaticResource btn}"/>
            <Button Content="Редагувати" Style="{StaticResource btn}" Click="EditDish_Click"/>
            <Button Content="Видалити" Click="DeleteDish_Click" Style="{StaticResource btn}"/>
        </StackPanel>
    </Grid>
</Window>
