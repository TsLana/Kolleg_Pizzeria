<Window x:Class="pizzeria.EmployeesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Співробітники" Style="{StaticResource WinStyle}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="EmployeesDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" FontSize="16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Прізвище та ім'я" Binding="{Binding employee_full_name}" Width="*"/>
                <DataGridTextColumn Header="Посада" Binding="{Binding position_name}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="На головний" Click="BackToMain_Click" Style="{StaticResource btnOrange}"/>
            <Button Content="Додати" Click="AddEmployee_Click" Style="{StaticResource btn}"/>
            <Button Content="Редагувати" Click="EditEmployee_Click" Style="{StaticResource btn}"/>
            <Button Content="Видалити" Click="DeleteEmployee_Click" Style="{StaticResource btn}"/>
        </StackPanel>
    </Grid>
</Window>
