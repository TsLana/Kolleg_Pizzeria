<Window x:Class="pizzeria.ClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клієнти" Style="{StaticResource WinStyle}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="ClientsDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" FontSize="16" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="Прізвище та ім'я" Binding="{Binding client_full_name}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding client_phone_number}" Width="*"/>
                <DataGridTextColumn Header="Кількість замовлень" Binding="{Binding order_count}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="На головний" Click="BackToMain_Click" Style="{StaticResource btnOrange}"/>
            <Button Content="Додати" Click="AddClient_Click" Style="{StaticResource btn}"/>
            <Button Content="Редагувати" Click="EditClient_Click" Style="{StaticResource btn}"/>
            <Button Content="Видалити" Click="DeleteClient_Click" Style="{StaticResource btn}"/>
        </StackPanel>

    </Grid>
</Window>
