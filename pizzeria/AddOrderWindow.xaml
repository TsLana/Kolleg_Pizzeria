<Window x:Class="pizzeria.AddOrderWindow"     
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Нове замовлення" Style="{StaticResource WinStyleAdd}" Height="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <StackPanel Width="300">
                <TextBlock Text="Дата:" Style="{StaticResource TextBlock}"/>
                <DatePicker x:Name="OrderDatePicker" FontSize="14" />
            </StackPanel>
            <StackPanel Margin="90,0,0,0">
                <TextBlock Text="Час:" Style="{StaticResource TextBlock}" />
                <StackPanel Orientation="Horizontal">
                    <ComboBox x:Name="HourComboBox" Width="70" Height="25" FontSize="14" />
                    <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0" FontSize="14" FontWeight="Bold"/>
                    <ComboBox x:Name="MinuteComboBox" Width="70" Height="25" FontSize="14"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Тип замовлення:" Style="{StaticResource TextBlock}" VerticalAlignment="Center"/>
            <ComboBox Width="300" x:Name="OrderTypeComboBox" Margin="10,5" Height="30" FontSize="14"
                      SelectionChanged="OrderTypeComboBox_SelectionChanged">
                <ComboBoxItem Content="Самовивіз"/>
                <ComboBoxItem Content="Доставка"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Клієнт (Прізвище та ім'я):" Style="{StaticResource TextBlock}" VerticalAlignment="Center"/>
            <TextBox x:Name="ClientNameTextBox" Width="250" Height="30"  FontSize="14" LostFocus="ClientNameTextBox_LostFocus" Margin="10,5" />
            <Button x:Name="AddClientButton" Content="Додати клієнта" Style="{StaticResource btn}" Click="AddClientButton_Click"  Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,0,0,10" x:Name="AddressPanel" Visibility="Collapsed" >
            <TextBlock Text="Адреса:" Style="{StaticResource TextBlock}" VerticalAlignment="Center" />
            <TextBox Width="300" Height="30" x:Name="AddressTextBox" Margin="10,5"  FontSize="14"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="4" Margin="0,0,0,10" x:Name="PhonePanel" Visibility="Collapsed" >
            <TextBlock Text="Номер телефону:" Style="{StaticResource TextBlock}" VerticalAlignment="Center" />
            <TextBox Width="300" Height="30" x:Name="PhoneTextBox" Margin="10,5"  FontSize="14"/>
        </StackPanel>

        <Button Grid.Row="5" Content="Додати страву" Style="{StaticResource btn}" Width="150" Height="40"  HorizontalAlignment="Center"
                Click="AddDishButton_Click" Margin="20" VerticalAlignment="Top"/>

        <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <ItemsControl x:Name="DishesItemsControl" ItemsSource="{Binding SelectedDishes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <ComboBox Width="250" Height="40"  FontSize="14"
                                      ItemsSource="{Binding DataContext.MenuItems, RelativeSource={RelativeSource AncestorType=Window}}"
                                      DisplayMemberPath="DishName"
                                      SelectedValuePath="DishId"
                                      SelectedValue="{Binding DishId, Mode=TwoWay}"/>
                            <TextBlock Text="{Binding DishPrice, StringFormat=₴{0:F2}}" Width="80" FontSize="14" Margin="10,0"
                                       VerticalAlignment="Center"/>
                            <TextBox Width="70" Height="20" Margin="10,0"  FontSize="14"
                                     VerticalAlignment="Center"
                                     Text="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     TextChanged="QuantityTextBox_TextChanged"/>
                            <Button Content="Видалити" Click="RemoveDishButton_Click"  Style="{StaticResource btn}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="7" Orientation="Vertical" HorizontalAlignment="Right" Margin="0,0,0,10">

            <StackPanel x:Name="DiscountedPanel" Visibility="Collapsed" Orientation="Vertical" HorizontalAlignment="Right" Margin="0,0,0,5">
                <TextBlock x:Name="DiscountTextBlock" FontSize="16" Foreground="#FF263E26" />
                <TextBlock x:Name="DiscountedTotalTextBlock" FontSize="16" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <TextBlock Text="Загальна сума:" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock x:Name="TotalPriceTextBlock" Text="₴0.00" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="DefaultPanel" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
                <TextBlock Text="Загальна сума:" Style="{StaticResource TextBlock}" FontSize="16" VerticalAlignment="Center" />
                <TextBlock x:Name="TotalPriceTextBlock_Default" Text="₴0.00" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>

        </StackPanel>


        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Зберегти замовлення" Style="{StaticResource btn}" Width="200" Click="SaveOrderButton_Click"/>
            <Button Content="Скасувати" Width="100" Style="{StaticResource btnOrange}" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>